{
  "manifest_version": 3,
  "name": "Copy Tab URL",
  "version": "1.0.0",
  "description": "Right-click any tab to copy its URL.",
  "permissions": ["tabs", "contextMenus", "clipboardWrite", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  }
}
