{
  "manifest_version": 3,
  "name": "Copy Tab URL",
  "version": "1.0.0",
  "description": "Click the toolbar icon or right-click the page to copy the tab's URL.",
  "permissions": ["tabs", "contextMenus", "clipboardWrite", "scripting", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Copy Tab URL",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
